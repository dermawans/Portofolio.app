---
import { profile } from '../data/profile';

const year = new Date().getFullYear();
---

<footer class="border-t border-surface-border/60 bg-surface-raised/30 py-10">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-6 px-4 sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <p class="text-sm text-slate-500">
      © {year} {profile.name}. Dibuat dengan Astro & Tailwind.
    </p>
    <div class="flex flex-wrap gap-4 text-sm">
      <a
        href={profile.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-400 transition hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
      >
        GitHub
      </a>
      {
        profile.social.linkedin && (
          <a
            href={profile.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 transition hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
          >
            LinkedIn
          </a>
        )
      }
      <a
        href={profile.email}
        class="text-slate-400 transition hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
      >
        Email
      </a>
    </div>
  </div>
</footer>
