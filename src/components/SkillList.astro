---
import { profile } from '../data/profile';
---

<ul class="flex flex-wrap gap-2" role="list">
  {
    profile.skills.map((skill) => (
      <li>
        <span class="inline-flex rounded-lg border border-surface-border bg-surface-raised/50 px-3 py-1.5 text-sm text-slate-200 transition hover:-translate-y-0.5 hover:border-accent/40 hover:text-white">
          {skill}
        </span>
      </li>
    ))
  }
</ul>
