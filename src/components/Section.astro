---
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
}

const { id, title, eyebrow } = Astro.props;
---

<section
  id={id}
  class="scroll-mt-24 border-t border-surface-border/60 py-16 sm:py-20"
  aria-labelledby={`${id}-heading`}
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    {
      eyebrow && (
        <p class="mb-2 text-xs font-medium uppercase tracking-widest text-accent">
          {eyebrow}
        </p>
      )
    }
    <h2
      id={`${id}-heading`}
      class="mb-8 text-2xl font-semibold tracking-tight text-white sm:text-3xl relative after:absolute after:-bottom-2 after:left-0 after:h-0.5 after:w-16 after:bg-gradient-to-r after:from-accent after:to-transparent after:content-['']"
    >
      {title}
    </h2>
    <slot />
  </div>
</section>
